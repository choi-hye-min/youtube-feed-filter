{
  "manifest_version": 3,
  "name": "YouTube Feed Filter",
  "version": "1.5.1",
  "description": "Filter YouTube home and watch-page recommendations by upload date.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "action": {
    "default_title": "YouTube Feed Filter",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "content-shared.js",
        "content-home.js",
        "content-watch.js",
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ]
}
